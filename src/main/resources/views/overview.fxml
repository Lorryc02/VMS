<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.OverviewController"
      spacing="25"
      style="-fx-background-color: #f5f7fa;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Grand titre VMS -->
    <VBox alignment="CENTER" spacing="10">
        <Label text="VMS"
               style="-fx-font-size: 72px; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
        <Label text="Voucher Management System"
               style="-fx-font-size: 18px; -fx-text-fill: #7f8c8d; -fx-font-weight: 500;"/>
    </VBox>

    <!-- Cartes de statistiques -->
    <HBox spacing="25" alignment="CENTER">

        <!-- Carte 1: Nombre de demandes -->
        <VBox spacing="10"
              style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2);
                     -fx-background-radius: 15;
                     -fx-padding: 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);"
              prefWidth="280" prefHeight="170">

            <Label text="📋 Demandes"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label fx:id="demandesCount"
                   text="0"
                   style="-fx-text-fill: white; -fx-font-size: 56px; -fx-font-weight: bold;"/>

            <Label text="Total des demandes créées"
                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
        </VBox>

        <!-- Carte 2: Nombre de clients -->
        <VBox spacing="10"
              style="-fx-background-color: linear-gradient(to bottom right, #f093fb, #f5576c);
                     -fx-background-radius: 15;
                     -fx-padding: 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);"
              prefWidth="280" prefHeight="170">

            <Label text="👥 Clients"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label fx:id="clientsCount"
                   text="0"
                   style="-fx-text-fill: white; -fx-font-size: 56px; -fx-font-weight: bold;"/>

            <Label text="Total des clients enregistrés"
                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
        </VBox>

        <!-- Carte 3: Nombre de vouchers -->
        <VBox spacing="10"
              style="-fx-background-color: linear-gradient(to bottom right, #4facfe, #00f2fe);
                     -fx-background-radius: 15;
                     -fx-padding: 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);"
              prefWidth="280" prefHeight="170">

            <Label text="🎟️ Vouchers"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label fx:id="vouchersCount"
                   text="0"
                   style="-fx-text-fill: white; -fx-font-size: 56px; -fx-font-weight: bold;"/>

            <Label text="Total des vouchers générés"
                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
        </VBox>

    </HBox>

    <!-- Section activité récente -->
    <VBox spacing="18"
          style="-fx-background-color: white;
                 -fx-background-radius: 15;
                 -fx-padding: 30;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

        <Label text="📈 Activité récente"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <Separator/>

        <HBox spacing="40" alignment="CENTER_LEFT">
            <VBox spacing="8" alignment="CENTER">
                <Label text="En attente de paiement"
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label fx:id="enAttentePaiement"
                       text="0"
                       style="-fx-text-fill: #e67e22; -fx-font-size: 38px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8" alignment="CENTER">
                <Label text="En attente d'approbation"
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label fx:id="enAttenteApprobation"
                       text="0"
                       style="-fx-text-fill: #3498db; -fx-font-size: 38px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8" alignment="CENTER">
                <Label text="Vouchers expirés"
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label fx:id="vouchersExpires"
                       text="0"
                       style="-fx-text-fill: #e74c3c; -fx-font-size: 38px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Message de bienvenue -->
    <VBox spacing="12"
          style="-fx-background-color: linear-gradient(to right, #56ab2f, #a8e063);
                 -fx-background-radius: 15;
                 -fx-padding: 25;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

        <Label fx:id="welcomeMessage"
               text="👋 Bienvenue sur VMS !"
               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

        <Label text="Gérez vos bons cadeau de manière simple et efficace."
               style="-fx-text-fill: rgba(255,255,255,0.95); -fx-font-size: 15px;"/>
    </VBox>

</VBox>
